# Server
PORT=3001
LOG_LEVEL=info

# Anthropic (LLM) — required
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOOL_ROUNDS=15

# Default system prompt (optional — overridden per request via /api/run)
# DEFAULT_SYSTEM_PROMPT=

# API authentication (optional — if set, all /api/* endpoints require this key
# via X-Api-Key header or Authorization: Bearer <key>)
# API_KEY=your_secret_api_key

# Tool cache TTL in milliseconds (0 = cache forever, default)
# TOOL_CACHE_TTL_MS=0

# ── MCP Providers (each is optional — only enabled if token is set) ──

# Sentry (stdio transport)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG_SLUG=your-org-slug
SENTRY_PROJECT_SLUG=your-project-slug
# Webhook signature secret (optional — if set, verifies sentry-hook-signature header)
# SENTRY_WEBHOOK_SECRET=your_webhook_secret

# ClickUp (HTTP transport)
CLICKUP_MCP_URL=https://mcp.clickup.com/mcp
CLICKUP_API_TOKEN=your_clickup_api_token
CLICKUP_WORKSPACE_ID=your_workspace_id
CLICKUP_LIST_ID=your_default_list_id

# ── API Optimization Settings ──

# Rate Limiting (adjust based on your ClickUp plan)
# Free: 30/min, 500/hour | Unlimited: 50/min, 1000/hour | Business+: 100/min, 5000/hour
CLICKUP_MAX_REQUESTS_PER_MINUTE=50
CLICKUP_MAX_REQUESTS_PER_HOUR=1000
CLICKUP_MAX_CONCURRENT_REQUESTS=5

# Cache TTL (time-to-live in milliseconds)
# Longer TTL = fewer API calls but potentially stale data
CACHE_TTL_WORKSPACE_HIERARCHY=1800000  # 30 minutes
CACHE_TTL_WORKSPACE_MEMBERS=3600000    # 1 hour
CACHE_TTL_LIST_DETAILS=1800000         # 30 minutes
CACHE_TTL_CUSTOM_FIELDS=3600000        # 1 hour
